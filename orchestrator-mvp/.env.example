# Copy to .env and fill in. Never commit .env.
CURSOR_API_KEY=crsr_...

# Orchestrator tuning
CONFIDENCE_THRESHOLD=0.72        # merge tolerance: minimum vote/judge confidence to trust the merge
R0_GATE_THRESHOLD=0.85           # R0 judge early-exit bar (judge-gated mode only; separate from merge)
DEFAULT_TIMEOUT_MS=90000         # per-worker hard timeout
ROUND_TIMEOUT_MS=30000           # wait for deliberation messages per round (simulated drops)
DELIBERATION_ROUNDS=0            # 0 = single-shot; 2 = propose + critique + revise
CRITICAL_THINKING=true           # when deliberation enabled: question round before propose
ACTIVE_WORKERS=factual,reasoning,advocate
PORT=3000

# Transport: inprocess (default), simulated, or webrtc (hub-and-spoke mesh)
TRANSPORT=inprocess
SIGNAL_PORT=3001
SIM_LATENCY_MS=200
SIM_JITTER_MS=100
SIM_DROP_RATE=0.05

# Collaborative compute: parallel scratchpad/claims alongside free-text (off | parallel)
SCRATCHPAD_MODE=off

# Session index store (JSON file; path ending in .db becomes .json index)
DB_PATH=data/orchestrator-index.json

# Model assignment per role. Run `npm run models` to list IDs available to your account.
WORKER_FACTUAL_MODEL=
WORKER_REASONING_MODEL=
WORKER_ADVOCATE_MODEL=
JUDGE_MODEL=

# Local SLM / embeddings (Ollama). Add "local" to ACTIVE_WORKERS to enable SLM worker.
OLLAMA_URL=http://localhost:11434
WORKER_LOCAL_MODEL=llama3.2:3b

# Voter similarity: embeddings (semantic, default) or tfidf (legacy)
SIMILARITY_MODE=embeddings
EMBEDDING_MODEL=nomic-embed-text

# Demo UI: on-device SLM names on phone nodes (real models still run underneath)
DEMO_EDGE_MODELS=true

# Full phone-mesh demo preset (uncomment + restart server):
# DELIBERATION_ROUNDS=2
# TRANSPORT=simulated
# DEMO_EDGE_MODELS=true
